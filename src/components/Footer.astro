    <div class="mb-8 flex items-center justify-center gap-5">
      {SOCIAL_LINKS.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel={link.icon === 'fa-mastodon' ? 'me noopener noreferrer' : 'noopener noreferrer'}
          aria-label={link.label}
          class="text-brand-muted transition-colors hover:text-brand-text"
        >
          <i class={`${link.icon.startsWith('fa-solid') ? '' : 'fa-brands '}${link.icon} text-lg`} />
        </a>
      ))}
    </div>
    <nav class="mb-6 flex items-center justify-center gap-6">
      <a href="/press" class="text-sm text-brand-muted transition-colors hover:text-brand-text">
        Press
      </a>
      <a href="/privacy" class="text-sm text-brand-muted transition-colors hover:text-brand-text">
        Privacy Policy
      </a>
      <a href="/terms" class="text-sm text-brand-muted transition-colors hover:text-brand-text">
        Terms of Service
      </a>
      <a href="/support" class="text-sm text-brand-muted transition-colors hover:text-brand-text">
        Support
      </a>
    </nav>
    <p class="text-sm text-brand-muted">
      &copy; {COPYRIGHT_YEAR} {COMPANY_NAME}. All rights reserved.
    </p>
  </div>
</footer>
