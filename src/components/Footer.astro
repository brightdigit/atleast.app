---
import AppStoreBadge from './AppStoreBadge.astro';
import BrightDigitLogo from './BrightDigitLogo.astro';
import SocialIcon from './icons/SocialIcon.astro';
import { APP_NAME, COMPANY_NAME, COMPANY_WEBSITE_URL, COPYRIGHT_YEAR, SOCIAL_LINKS } from '../config';
---

<footer class="border-t border-brand-border/50 py-16">
  <div class="mx-auto max-w-5xl px-6 text-center">
    <img
      src="/press/icons/watchos/icon-512.webp"
      alt="AtLeast app icon"
      width="48"
      height="48"
      class="mx-auto mb-6 h-12 w-12 rounded-full"
      loading="lazy"
    />
    <AppStoreBadge class="mb-8" />
    <a
      href={COMPANY_WEBSITE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="group mb-8 block text-brand-muted transition-colors hover:text-brand-text"
    >
      <span class="text-sm italic">{APP_NAME} is developed by</span>
      <BrightDigitLogo class="inline-block h-7 w-auto align-middle text-brand-text transition-colors duration-300 group-hover:text-[#f9ed32]" />
    </a>
    <div class="mb-8 flex items-center justify-center gap-5">
      {SOCIAL_LINKS.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel={link.icon === 'mastodon' ? 'me noopener noreferrer' : 'noopener noreferrer'}
          aria-label={link.label}
          class="text-brand-muted transition-colors hover:text-brand-text"
        >
          <SocialIcon name={link.icon} />
        </a>
      ))}
    </div>
    <nav class="mb-6 flex items-center justify-center gap-6">
      <a href="/press" class="text-sm text-brand-muted transition-colors hover:text-brand-text">
        Press
      </a>
      <a href="/privacy" class="text-sm text-brand-muted transition-colors hover:text-brand-text">
        Privacy Policy
      </a>
      <a href="/terms" class="text-sm text-brand-muted transition-colors hover:text-brand-text">
        Terms of Service
      </a>
      <a href="/support" class="text-sm text-brand-muted transition-colors hover:text-brand-text">
        Support
      </a>
    </nav>
    <p class="text-sm text-brand-muted">
      &copy; {COPYRIGHT_YEAR} {COMPANY_NAME}. All rights reserved.
    </p>
  </div>
</footer>
