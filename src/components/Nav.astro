---
import { TESTFLIGHT_URL } from '../config';

const links = [
  { href: '/press', label: 'Press' },
  { href: '/privacy', label: 'Privacy' },
  { href: '/terms', label: 'Terms' },
  { href: '/support', label: 'Support' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-brand-border/50 bg-brand-bg/80 backdrop-blur-lg">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tight text-brand-text">
      <img
        src="/press/icons/watchos/icon-512.webp"
        alt=""
        width="28"
        height="28"
        class="h-7 w-7 rounded-full"
        loading="eager"
      />
      AtLeast
    </a>
    <div class="flex items-center gap-6">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-brand-muted transition-colors hover:text-brand-text"
        >
          {link.label}
        </a>
      ))}
      <a
        href={TESTFLIGHT_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full border border-brand-border bg-brand-surface px-4 py-1.5 text-sm text-brand-text transition-opacity hover:opacity-80"
      >
        Join Beta
      </a>
    </div>
  </div>
</nav>
