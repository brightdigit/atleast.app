---
import { Icon } from 'astro-icon/components';

interface Props {
  icon: string;
  id?: string;
}

const { icon, id } = Astro.props;
---

<div id={id} class:list={['mt-16 flex items-center gap-4', id && 'scroll-mt-24']}>
  <span
    class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl border border-brand-border bg-brand-surface"
  >
    <Icon name={icon} class="h-6 w-6 text-brand-accent" />
  </span>
  <h2 class="text-3xl font-semibold tracking-tight">
    <slot />
  </h2>
</div>
