---
interface Props {
  step: number;
  title: string;
  description: string;
}

const { step, title, description } = Astro.props;
---

<div class="rounded-2xl border border-brand-border bg-brand-surface p-6">
  <span class="mb-3 inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-accent/10 text-sm font-semibold text-brand-accent">
    {step}
  </span>
  <h3 class="mb-2 text-lg font-semibold text-brand-text">{title}</h3>
  <p class="text-sm leading-relaxed text-brand-muted">{description}</p>
</div>
