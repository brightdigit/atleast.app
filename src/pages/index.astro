---
import Layout from '../layouts/Layout.astro';
import StepCard from '../components/StepCard.astro';
import UseCaseCard from '../components/UseCaseCard.astro';
import FeatureRow from '../components/FeatureRow.astro';
import AppStoreBadge from '../components/AppStoreBadge.astro';
import Schema from '../components/Schema.astro';

const steps = [
  {
    step: 1,
    title: 'Set your minimum',
    description: 'Choose a duration (1–60 min) and tap interval.',
  },
  {
    step: 2,
    title: 'Feel the rhythm',
    description: 'Gentle haptic taps keep you present without distraction.',
  },
  {
    step: 3,
    title: 'Silence means done',
    description: 'When taps stop, you\'ve reached your goal. No alarm. No interruption.',
  },
];

const useCases = [
  { emoji: '🧘', label: 'Meditation', description: 'Stay present without watching the clock.' },
  { emoji: '🧊', label: 'Cold exposure', description: 'Know when your minimum is reached — eyes-free.' },
  { emoji: '🧘‍♀️', label: 'Yoga & stretching', description: 'Hold poses with a gentle rhythm guiding you.' },
  { emoji: '🏋️', label: 'Static holds', description: 'Planks, wall sits — feel the time without seeing it.' },
  { emoji: '💻', label: 'Focused work', description: 'Pomodoro-style sessions with silent completion.' },
];

const features = [
  {
    icon: '🔕',
    heading: 'No jarring alarm.',
    description: 'Traditional timers interrupt the very state you\'re trying to maintain. <em>AtLeast</em> inverts this — taps encourage you during practice and go silent when you\'ve earned it.',
  },
  {
    icon: '⌚',
    heading: 'Eyes-free, by design.',
    description: 'Built for Apple Watch. No screen-checking, no distractions. Just gentle taps on your wrist.',
  },
  {
    icon: '🌱',
    heading: '"At least" mindset.',
    description: 'Setting a minimum threshold, not a hard deadline. More forgiving. More human.',
  },
];

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'AtLeast',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'watchOS 26.0',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description:
    'AtLeast is a passive haptic timer for Apple Watch that uses gentle taps to mark time intervals during meditation, breathwork, and cold plunge sessions — no screens, just rhythm.',
  featureList: [
    'Haptic-only timers — no screen required',
    'Works completely offline',
    'Perfect for meditation, breathwork, and cold plunge',
    'Apple Watch native app',
  ],
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to use AtLeast timer on Apple Watch',
  description: 'Set up a passive haptic timer on Apple Watch in 3 simple steps.',
  step: steps.map((s) => ({
    '@type': 'HowToStep',
    name: s.title,
    text: s.description,
  })),
};
---

<Layout
  title="AtLeast — Passive Timer for Apple Watch"
  description="Gentle haptic taps during your practice. Silence means done. No alarm. No interruption. A mindful timer for meditation, cold plunge, yoga, and focused work."
>
  <Schema schema={softwareSchema} />
  <Schema schema={howToSchema} />

  <!-- Hero -->
  <section class="relative flex min-h-[85vh] flex-col items-center justify-center px-6 py-24 text-center">
    <div class="relative flex items-center justify-center">
      <span class="absolute h-64 w-64 rounded-full border-2 border-brand-accent/40" style="animation: ripple 4.5s ease-out infinite;" aria-hidden="true"></span>
      <span class="absolute h-64 w-64 rounded-full border-2 border-brand-pulse/40" style="animation: ripple 4.5s ease-out 1.5s infinite;" aria-hidden="true"></span>
      <span class="absolute h-64 w-64 rounded-full border-2 border-brand-accent/40" style="animation: ripple 4.5s ease-out 3s infinite;" aria-hidden="true"></span>
      <img
        src="/press/icons/watchos/icon-512.webp"
        alt="AtLeast app icon"
        width="256"
        height="256"
        class="relative h-64 w-64 rounded-full"
        loading="eager"
      />
    </div>
    <h1 class="mt-12 text-5xl font-bold tracking-tight md:text-7xl">
      Done when the silence comes.
    </h1>
    <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-brand-muted">
      <em>AtLeast</em> taps your Apple Watch gently during your practice. When tapping stops, you've reached your minimum.
    </p>
    <p class="sr-only">
      <em>AtLeast</em> is a passive haptic timer for Apple Watch. It uses gentle taps to mark time intervals during meditation, breathwork, and cold plunge sessions — no screens, just rhythm.
    </p>
    <AppStoreBadge class="mt-8" />
  </section>

  <!-- How It Works -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <h2 class="mb-12 text-center text-3xl font-semibold md:text-4xl">How does <em>AtLeast</em> work?</h2>
      <div class="grid gap-6 md:grid-cols-3">
        {steps.map((s) => <StepCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <h2 class="mb-12 text-center text-3xl font-semibold md:text-4xl">Built for practice</h2>
      <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory md:grid md:grid-cols-5 md:overflow-visible md:pb-0">
        {useCases.map((uc) => <UseCaseCard {...uc} />)}
      </div>
    </div>
  </section>

  <!-- Why AtLeast -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-semibold md:text-4xl">Why choose <em>AtLeast</em>?</h2>
      <div class="space-y-10">
        {features.map((f) => <FeatureRow {...f} />)}
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-semibold md:text-4xl"><em>AtLeast</em> vs traditional timer apps</h2>
      <div class="overflow-x-auto rounded-2xl border border-brand-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-brand-border bg-brand-surface">
              <th class="px-6 py-4 text-left font-medium text-brand-muted">Feature</th>
              <th class="px-6 py-4 text-left font-semibold text-brand-text"><em>AtLeast</em></th>
              <th class="px-6 py-4 text-left font-medium text-brand-muted">Traditional apps</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-brand-border">
            <tr class="bg-brand-surface/50">
              <td class="px-6 py-4 text-brand-muted">Screen required</td>
              <td class="px-6 py-4 text-brand-accent">No — haptic only</td>
              <td class="px-6 py-4 text-brand-muted">Yes</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-brand-muted">Works offline</td>
              <td class="px-6 py-4 text-brand-accent">Fully offline</td>
              <td class="px-6 py-4 text-brand-muted">Often requires internet</td>
            </tr>
            <tr class="bg-brand-surface/50">
              <td class="px-6 py-4 text-brand-muted">Platform</td>
              <td class="px-6 py-4 text-brand-accent">Apple Watch native</td>
              <td class="px-6 py-4 text-brand-muted">iPhone-based</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-brand-muted">End signal</td>
              <td class="px-6 py-4 text-brand-accent">Gentle silence</td>
              <td class="px-6 py-4 text-brand-muted">Jarring alarm</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Simplicity -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-3xl font-semibold md:text-4xl">Simple by design.</h2>
      <p class="mx-auto mb-10 max-w-xl text-lg leading-relaxed text-brand-muted">
        No account required. No phone needed. Just your Apple Watch and your practice.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-6">
        <span class="flex items-center gap-2 rounded-full border border-brand-border bg-brand-surface px-5 py-2.5 text-sm text-brand-muted">
          <span class="text-base">👤</span> No account required
        </span>
        <span class="flex items-center gap-2 rounded-full border border-brand-border bg-brand-surface px-5 py-2.5 text-sm text-brand-muted">
          <span class="text-base">⌚</span> Runs on Apple Watch
        </span>
        <span class="flex items-center gap-2 rounded-full border border-brand-border bg-brand-surface px-5 py-2.5 text-sm text-brand-muted">
          <span class="text-base">📴</span> Works offline
        </span>
      </div>
    </div>
  </section>
</Layout>
