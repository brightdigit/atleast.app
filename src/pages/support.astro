---
import Layout from '../layouts/Layout.astro';
import Schema from '../components/Schema.astro';

const faqs = [
  {
    question: 'Why did my taps stop before my timer finished?',
    answer: 'If taps stopped, you\'ve reached your minimum duration. The silence is intentional — it means you\'re done.',
  },
  {
    question: 'Can I use <em>AtLeast</em> with the screen off?',
    answer: 'Yes. <em>AtLeast</em> uses an Extended Runtime Session to continue haptics with the watch face off.',
  },
  {
    question: 'Why doesn\'t <em>AtLeast</em> alarm when it finishes?',
    answer: 'That\'s by design. The absence of taps is the signal. No alarm means no interruption to your flow state.',
  },
  {
    question: 'What Apple Watch models are supported?',
    answer: 'Apple Watch Series 6 or later running watchOS 26.0 or later.',
  },
  {
    question: 'Can I use <em>AtLeast</em> without my iPhone?',
    answer: 'Yes. The watchOS app runs independently.',
  },
  {
    question: 'What is a passive timer?',
    answer: 'A passive timer runs in the background without requiring your attention. <em>AtLeast</em> uses haptic taps — gentle vibrations on your wrist — to mark intervals, so you can keep your eyes closed during meditation or stay focused during breathwork without ever checking a screen.',
  },
  {
    question: 'Does <em>AtLeast</em> require an account?',
    answer: 'No. <em>AtLeast</em> works right away with no account, no sign-up, and no setup. Just open the app on your Apple Watch and start.',
  },
  {
    question: 'Is <em>AtLeast</em> good for cold plunge sessions?',
    answer: 'Yes. <em>AtLeast</em> is perfect for cold plunge because you can keep your eyes closed and focus on breathing while gentle taps mark your intervals. It works completely offline on Apple Watch — no phone needed.',
  },
  {
    question: 'Does <em>AtLeast</em> work offline?',
    answer: 'Yes. <em>AtLeast</em> runs entirely on your Apple Watch with no internet connection required. Perfect for airplane meditation, remote locations, or simply staying disconnected.',
  },
  {
    question: 'Can I use <em>AtLeast</em> for breathwork?',
    answer: 'Absolutely. <em>AtLeast</em> pairs naturally with Wim Hof, box breathing, and 4-7-8 breathing techniques. Set an interval to match your breath cycles and let the gentle taps guide your rhythm — eyes closed, fully present.',
  },
];

const stripHtml = (str: string) => str.replace(/<[^>]*>/g, '');

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: stripHtml(faq.question),
    acceptedAnswer: {
      '@type': 'Answer',
      text: stripHtml(faq.answer),
    },
  })),
};
---

<Layout
  title="Support — AtLeast"
  description="Frequently asked questions and support contact for AtLeast, the passive Apple Watch timer."
>
  <Schema schema={faqSchema} />

  <section class="px-6 py-24">
    <div class="mx-auto max-w-2xl">
      <h1 class="mb-12 text-4xl font-bold tracking-tight md:text-5xl">Support</h1>

      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-2xl border border-brand-border bg-brand-surface">
            <summary class="cursor-pointer px-6 py-5 text-base font-medium text-brand-text list-none flex items-center justify-between">
              <span set:html={faq.question} />
              <span class="ml-4 flex-shrink-0 text-brand-muted transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="px-6 pb-5 text-base leading-relaxed text-brand-muted" set:html={faq.answer} />
          </details>
        ))}
      </div>

      <div class="mt-16 rounded-2xl border border-brand-border bg-brand-surface p-8 text-center">
        <h2 class="mb-3 text-xl font-semibold text-brand-text">Still have questions?</h2>
        <p class="text-base text-brand-muted">
          Email us at
          <a href="mailto:support@atleast.app" class="text-brand-accent underline">
            support@atleast.app
          </a>
        </p>
      </div>
    </div>
  </section>
</Layout>
